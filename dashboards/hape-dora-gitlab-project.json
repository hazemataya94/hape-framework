{
  "title": "HAPE / DORA / GitLab / Project",
  "uid": "hape-dora-gitlab-project",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "1m",
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "group",
        "type": "query",
        "label": "Group",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(hape_dora_project_info, group_path)"
      },
      {
        "name": "project",
        "type": "query",
        "label": "Project",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(hape_dora_project_info{group_path=\"$group\"}, project_path)"
      },
      {
        "name": "window",
        "type": "custom",
        "label": "Window",
        "query": "7d,30d,90d",
        "current": {
          "selected": true,
          "text": "30d",
          "value": "30d"
        }
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(hape_dora_deployments_total, environment)",
        "includeAll": true
      },
      {
        "name": "cluster",
        "type": "custom",
        "label": "Cluster",
        "query": "kind-hape",
        "current": {
          "selected": true,
          "text": "kind-hape",
          "value": "kind-hape"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Deployments Over Time",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hape_dora_deployments_total{project_path=\"$project\",window=\"$window\",environment=~\"$environment\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Deployment Frequency",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hape_dora_deployment_frequency_per_day{project_path=\"$project\",window=\"$window\",environment=~\"$environment\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Lead Time Trend",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hape_dora_lead_time_seconds{project_path=\"$project\",window=\"$window\",environment=~\"$environment\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failed Deployments Count",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hape_dora_failed_deployments_total{project_path=\"$project\",window=\"$window\",environment=~\"$environment\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Change Fail Rate Trend",
      "gridPos": {
        "h": 8,
        "w": 9,
        "x": 6,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hape_dora_change_fail_rate_ratio{project_path=\"$project\",window=\"$window\",environment=~\"$environment\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Recovery Time Trend",
      "gridPos": {
        "h": 8,
        "w": 9,
        "x": 15,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hape_dora_failed_deployment_recovery_time_seconds{project_path=\"$project\",window=\"$window\",environment=~\"$environment\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Recent Deployment Events Summary",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hape_dora_deployments_total{project_path=\"$project\",window=\"$window\",environment=~\"$environment\"}",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    }
  ]
}
