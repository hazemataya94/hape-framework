{
  "title": "HAPE / DORA / GitHub / Group",
  "uid": "hape-dora-github-group",
  "schemaVersion": 42,
  "version": 2,
  "editable": true,
  "refresh": "1m",
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "group",
        "type": "query",
        "label": "Group",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(hape_dora_project_info{provider=\"github\"}, group_path)"
      },
      {
        "name": "window",
        "type": "custom",
        "label": "Window",
        "query": "7d,30d,90d",
        "current": {
          "selected": true,
          "text": "30d",
          "value": "30d"
        }
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(hape_dora_deployments_total{provider=\"github\"}, environment)",
        "includeAll": true
      },
      {
        "name": "cluster",
        "type": "custom",
        "label": "Cluster",
        "query": "kind-hape",
        "current": {
          "selected": true,
          "text": "kind-hape",
          "value": "kind-hape"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Top 10 Highest Deployment Frequency",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, hape_dora_deployment_frequency_per_day{provider=\"github\",window=\"$window\",environment=~\"$environment\",group_path=\"$group\"})",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "footer": {
              "reducers": []
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "project_path",
                "window",
                "Value"
              ]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "includeByName": {},
            "indexByName": {},
            "renameByName": {
              "Value": "Deployments Per Day",
              "project_path": "Repository",
              "window": "Window"
            }
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Top 10 Lowest Non-Zero Deployment Frequency",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "bottomk(10, hape_dora_deployment_frequency_per_day{provider=\"github\",window=\"$window\",environment=~\"$environment\",group_path=\"$group\"} > 0)",
