        "x": 12,
        "y": 36
      },
      "targets": [
        {
          "refId": "A",
          "expr": "bottomk(10, hape_dora_failed_deployment_recovery_time_seconds{window=\"$window\",environment=~\"$environment\"} > 0)",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "datasource": {
