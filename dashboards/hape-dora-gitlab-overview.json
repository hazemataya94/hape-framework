        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, (hape_dora_lead_time_seconds{window=\"$window\",environment=~\"$environment\"} == 0))",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
