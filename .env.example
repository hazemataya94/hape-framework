# Logging
HAPE_LOG_LEVEL=DEBUG # optional; one of DEBUG, INFO, WARNING, ERROR, CRITICAL
HAPE_ENABLE_LOG_FILE=0 # optional; 0/1 or false/true
HAPE_LOG_FILE="/path/to/hape.log" # optional; used when HAPE_ENABLE_LOG_FILE is on

# API
HAPE_API_HOST="0.0.0.0" # optional; API bind host
HAPE_API_PORT=8080 # optional; API bind port
HAPE_API_ADMIN_KEY="" # required for API token management endpoints
HAPE_API_TOKENS_FILE="~/.hape/api-tokens.json" # optional; local JSON token store
HAPE_API_RATE_LIMIT_PER_MINUTE=10 # optional; requests per minute per token

# Exporter
HAPE_EXPORTER_HOST="0.0.0.0" # optional; default bind host for exporter
HAPE_EXPORTER_PORT=9117 # optional; default exporter port
HAPE_EXPORTER_REFRESH_SECONDS=300 # optional; refresh interval in seconds

# DORA exporter
HAPE_DORA_EXPORTER_HOST="0.0.0.0" # optional; default bind host for DORA exporter (falls back to HAPE_EXPORTER_HOST)
HAPE_DORA_EXPORTER_PORT=9120 # optional; DORA exporter port (falls back to HAPE_EXPORTER_PORT)
HAPE_DORA_EXPORTER_REFRESH_SECONDS=300 # optional; DORA exporter refresh interval in seconds
HAPE_DORA_GITLAB_GROUP_IDS="123,456" # required for DORA scans if GITLAB_DEFAULT_GROUP_ID is not set
HAPE_DORA_GIT_RULES_PATH="config/dora/git-rules.json" # optional; git-based deployment detection rules path
HAPE_DORA_KUBERNETES_MAPPINGS_PATH="config/dora/kubernetes-mappings.json" # optional; Kubernetes mappings path
HAPE_DORA_PROMETHEUS_URL="http://localhost:9090" # optional; Prometheus URL used for post-deploy failure detection
HAPE_DORA_KUBE_CONTEXT="" # optional; Kubernetes context name used by DORA-related diagnostics
HAPE_DORA_PROVIDER="gitlab" # optional; one of gitlab or github
HAPE_GITHUB_API_URL="https://api.github.com" # optional; GitHub API base URL
HAPE_GITHUB_TOKEN="" # required when HAPE_DORA_PROVIDER=github unless GitHub App auth vars are set
HAPE_GITHUB_DEFAULT_OWNER="" # optional; default owner for github init-repo when --owner is not set
HAPE_GITHUB_APP_ID=0 # optional; GitHub App ID for installation token auth
HAPE_GITHUB_INSTALLATION_ID=0 # optional; GitHub App installation ID
HAPE_GITHUB_APP_PRIVATE_KEY_PATH="" # optional; path to GitHub App private key PEM
HAPE_DORA_GITHUB_ORGS="example-org" # required when HAPE_DORA_PROVIDER=github; comma-separated org names

# EKS deployment cost exporter
HAPE_EDC_KUBE_CONTEXT="" # optional; if empty, active kube context is used
HAPE_EDC_AWS_PROFILE="" # optional; if empty, default boto3 profile resolution is used
HAPE_EDC_IGNORED_NAMESPACES="kube-system,kube-node-lease,kube-public,local-path-storage" # optional; comma-separated namespaces to ignore

# Kube agent
HAPE_KUBE_AGENT_PROMETHEUS_URL="http://localhost:9090" # optional; Prometheus API base URL
HAPE_KUBE_AGENT_GRAFANA_URL="http://localhost:3000" # optional; Grafana API base URL
HAPE_KUBE_AGENT_GRAFANA_TOKEN="" # optional; Grafana Bearer token for API auth
HAPE_KUBE_AGENT_GRAFANA_USERNAME="" # optional; Grafana basic auth username
HAPE_KUBE_AGENT_GRAFANA_PASSWORD="" # optional; Grafana basic auth password
HAPE_KUBE_AGENT_ALERTMANAGER_URL="http://localhost:9093" # optional; Alertmanager API base URL
HAPE_KUBE_AGENT_SQLITE_PATH="~/.hape/kube-agent.sqlite" # optional; local SQLite path for incident memory
HAPE_KUBE_AGENT_AI_ENABLED=false # optional; default AI behavior for kube-agent investigations
HAPE_KUBE_AGENT_AI_STALE_HOURS=6 # optional; rerun AI after this many hours
HAPE_KUBE_AGENT_RESTART_THRESHOLD=3 # optional; restart threshold used by deterministic checks
HAPE_KUBE_AGENT_POD_LOG_TAIL_LINES=200 # optional; default pod log tail size
HAPE_KUBE_AGENT_LOOKBACK_MINUTES=30 # optional; default evidence time window
HAPE_KUBE_AGENT_SLACK_CHANNEL="" # optional; default Slack channel for findings output
HAPE_KUBE_AGENT_COST_TOTAL_HOURLY_USD_THRESHOLD=20.0 # optional; alert threshold for total hourly cost
HAPE_KUBE_AGENT_COST_WORKLOAD_HOURLY_USD_THRESHOLD=5.0 # optional; alert threshold for one deployment hourly cost
HAPE_KUBE_AGENT_COST_INCREASE_RATIO_THRESHOLD=1.5 # optional; alert threshold for current vs historical hourly ratio
HAPE_KUBE_AGENT_COST_TOP_WORKLOADS_LIMIT=5 # optional; number of top workloads collected as evidence

# GitLab
HAPE_GITLAB_DOMAIN="your-gitlab-domain" # e.g. gitlab.com
GITLAB_TOKEN=""
GITLAB_DEFAULT_GROUP_ID=123 # must be an integer

# Kubernetes
KUBERNETES_CONTEXT="name-of-kube-context"

# Atlassian
ATLASSIAN_DOMAIN="company.atlassian.net"
ATLASSIAN_EMAIL="your.name@company.com"
ATLASSIAN_API_KEY="your-api-key"
CONFLUENCE_CHANGELOG_PARENT_PAGE_ID=123 # must be an integer
CONFLUENCE_CHANGELOG_ENTRY_PAGE_TEMPLATE_ID=123 # must be an integer
CONFLUENCE_TEST_PARENT_PAGE_ID=123 # must be an integer

# Grafana
GRAFANA_DOMAIN="grafana.example.com" # optional; used by grafana command when cli flag is not passed
GRAFANA_PORT=443 # optional; defaults to 443 if not set. 443 uses https, other ports use http
GRAFANA_TOKEN="" # optional; token auth for grafana command
GRAFANA_USERNAME="" # optional; basic auth username for grafana command
GRAFANA_PASSWORD="" # optional; basic auth password for grafana command
GRAFANA_DEPLOYMENTS_SUBPATH="monitor-system/grafana2/grafana2" # optional; used by grafana command when cli flag is not passed
